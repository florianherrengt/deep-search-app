{
  "name": "deep-search-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "prepare:sidecars": "node scripts/prepare-node-sidecar.mjs",
    "preview": "vite preview",
    "release:set-version": "node scripts/set-release-version.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "storybook:screenshots": "npm run build-storybook && node scripts/storybook-screenshots.mjs",
    "storybook:screenshots:dev": "node scripts/storybook-screenshots.mjs --url http://127.0.0.1:6006",
    "tauri": "npm run prepare:sidecars && tauri",
    "test": "vitest run --project unit",
    "test:browser": "vitest run --project storybook",
    "test:all": "vitest run",
    "test:watch": "vitest --project unit",
    "test:e2e": "npm test --prefix e2e-tests",
    "test:visual": "npm run build-storybook && node scripts/visual-snapshot-test.mjs",
    "test:visual:update": "npm run build-storybook && node scripts/visual-snapshot-test.mjs -- --update",
    "test:visual:dev": "node scripts/visual-snapshot-test.mjs -- --url http://127.0.0.1:6006"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.79",
    "@ai-sdk/react": "^3.0.187",
    "@assistant-ui/react": "^0.14.5",
    "@assistant-ui/react-ai-sdk": "^1.3.26",
    "@assistant-ui/react-markdown": "^0.14.0",
    "@mantine/core": "^7.17.8",
    "@mantine/form": "^7.17.8",
    "@mantine/hooks": "^7.17.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "ai": "^6.0.185",
    "cheerio": "^1.2.0",
    "chrome-devtools-mcp": "^1.1.1",
    "currency-symbol-map": "^5.1.0",
    "ipaddr.js": "^2.4.0",
    "lucide-react": "^1.16.0",
    "p-queue": "^9.3.0",
    "postcss": "^8.5.15",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remark-gfm": "^4.0.1",
    "slugify": "^1.6.9",
    "zhipu-ai-provider": "^0.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.4.2",
    "@storybook/addon-docs": "^10.4.2",
    "@storybook/addon-vitest": "^10.4.2",
    "@storybook/react-vite": "^10.4.2",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.9.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/browser": "^4.1.8",
    "@vitest/browser-playwright": "^4.1.8",
    "node": "^25.9.0",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0",
    "storybook": "^10.4.2",
    "storybook-addon-vis": "^4.2.3",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
