{
  "name": "deep-search-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "release:set-version": "node scripts/set-release-version.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "storybook:screenshots": "npm run build-storybook && node scripts/storybook-screenshots.mjs",
    "storybook:screenshots:dev": "node scripts/storybook-screenshots.mjs --url http://127.0.0.1:6006",
    "tauri": "tauri",
    "tauri:build:release": "tauri build --config src-tauri/tauri.release.conf.json",
    "test": "vitest run --project unit",
    "test:unit:quiet": "mkdir -p .agent-logs && vitest run --project unit --reporter=minimal --silent=passed-only --bail=1 2>&1 | tee .agent-logs/vitest.log | tail -n 80",
    "test:unit:focused": "vitest run --project unit --reporter=minimal --silent=passed-only --bail=1",
    "test:browser": "vitest run --project storybook",
    "test:all": "vitest run",
    "test:watch": "vitest --project unit",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:e2e:tauri": "npm test --prefix e2e-tests",
    "test:visual": "npm run build-storybook && node scripts/visual-snapshot-test.mjs",
    "test:visual:update": "npm run build-storybook && node scripts/visual-snapshot-test.mjs -- --update",
    "test:visual:dev": "node scripts/visual-snapshot-test.mjs -- --url http://127.0.0.1:6006",
    "benchmark:subagents": "BENCHMARK_LABEL=current node scripts/benchmark-sub-agent-streaming.mjs",
    "benchmark:research-search": "cargo run --manifest-path src-tauri/Cargo.toml --bin research-search-benchmark",
    "benchmark:research-search:refresh": "cargo run --manifest-path src-tauri/Cargo.toml --bin research-search-benchmark -- --refresh",
    "benchmark:research-search:validate-chunking": "cargo run --manifest-path src-tauri/Cargo.toml --bin research-search-benchmark -- --validate-chunking",
    "benchmark:research-search:real:generate": "node scripts/generate-research-search-corpus.mjs",
    "benchmark:research-search:real:regenerate": "node scripts/generate-research-search-corpus.mjs --force",
    "benchmark:research-search:real": "cargo run --manifest-path src-tauri/Cargo.toml --bin research-search-benchmark -- --corpus benchmarks/research-search/fixtures/real-corpus.json --cache benchmarks/research-search/fixtures/real-provider-cache.json --report-dir benchmarks/research-search/results-real",
    "benchmark:research-search:real:validate-chunking": "cargo run --manifest-path src-tauri/Cargo.toml --bin research-search-benchmark -- --validate-chunking --corpus benchmarks/research-search/fixtures/real-corpus.json --cache benchmarks/research-search/fixtures/real-provider-cache.json --report-dir benchmarks/research-search/results-real",
    "benchmark:research-search:real:refresh": "cargo run --manifest-path src-tauri/Cargo.toml --bin research-search-benchmark -- --refresh --corpus benchmarks/research-search/fixtures/real-corpus.json --cache benchmarks/research-search/fixtures/real-provider-cache.json --report-dir benchmarks/research-search/results-real"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.79",
    "@ai-sdk/deepseek": "^2.0.38",
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@ai-sdk/react": "^3.0.187",
    "@assistant-ui/react": "^0.14.5",
    "@assistant-ui/react-ai-sdk": "^1.3.26",
    "@assistant-ui/react-markdown": "^0.14.0",
    "@deep-search/search-extract": "github:florianherrengt/search-extract",
    "@mantine/core": "^7.17.8",
    "@mantine/form": "^7.17.8",
    "@mantine/hooks": "^7.17.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "ai": "^6.0.185",
    "cheerio": "^1.2.0",
    "chrome-devtools-mcp": "^1.1.1",
    "currency-symbol-map": "^5.1.0",
    "ipaddr.js": "^2.4.0",
    "lucide-react": "^1.16.0",
    "p-queue": "^9.3.0",
    "postcss": "^8.5.15",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "research-orchestrator": "github:florianherrengt/research-orchestrator#v0.2.1",
    "slugify": "^1.6.9",
    "zhipu-ai-provider": "^0.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@srsholmes/tauri-playwright": "^0.4.0",
    "@storybook/addon-a11y": "^10.4.2",
    "@storybook/addon-docs": "^10.4.2",
    "@storybook/addon-vitest": "^10.4.2",
    "@storybook/react-vite": "^10.4.2",
    "@tauri-apps/cli": "^2",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/browser": "^4.1.8",
    "@vitest/browser-playwright": "^4.1.8",
    "jsdom": "^29.1.1",
    "node-pty": "^1.1.0",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0",
    "storybook": "^10.4.2",
    "storybook-addon-vis": "^4.2.3",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
